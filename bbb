#!/usr/bin/env bash
#
# bb-bash - Bitbucket Cloud API wrapper
#
# Reads credentials from .env file next to the *real* script (symlinks are
# resolved through resolve_script_dir, so a PATH symlink at /usr/local/bin or
# ~/.local/bin still locates .env in the data directory). Copy .env.example
# to .env and fill in your values, or install via the curl-pipe-bash flow
# documented in README.md / scripts/install.sh.
#
# Usage (see usage() for the live list; this header summarizes):
#   bbb pr list [--state=<s>] [--author=<u>]   - List PRs (default: open)
#   bbb pr create <target> <title> [desc]      - Create PR from current branch
#   bbb pr update <id> [--title=...] [--description=...] [--reviewers=u1,u2]
#                                                 - Update PR metadata
#   bbb pr show <id>                           - PR details + changed files
#   bbb pr open <id>                           - Open PR in default browser
#   bbb pr diff <id>                           - Full diff
#   bbb pr checks <id>                         - CI statuses + Bitbucket Pipelines
#   bbb pr comments <id>                       - List comments
#   bbb pr comment <id> <text>                 - Add general comment
#   bbb pr inline [--old] <id> <path> <line> <text>
#                                                 - Inline comment (default new code; --old for deleted)
#   bbb pr approve <id> [id ...]               - Approve PR(s), batch-capable
#   bbb pr decline <id> [id ...]               - Decline (close without merge), batch-capable
#   bbb pr merge <id> [--squash|--commit|--ff] [--delete-branch] [--message=...]
#                                                 - Merge PR (default strategy: merge_commit)
#   bbb pr reply <pr_id> <comment_id> <text>   - Reply to a comment
#   bbb pr edit-comment <pr_id> <comment_id> <text>
#                                                 - Edit a comment
#   bbb pr delete-comment <pr_id> <comment_id> - Delete a comment
#   bbb raw <endpoint>                         - Raw API call (GET)
#   bbb raw-post <endpoint> <json>             - Raw API call (POST)
#   bbb install-agent [--rule] [--skill] [--claudemd] [--agents]
#                                                 - Drop AI-agent integration artifacts into $PWD

set -euo pipefail

# --- Config ---
# Email and token are required for all invocations; WORKSPACE/REPO are
# resolved by the top-level block at the bottom of this file, via
# resolve_workspace_repo(). When sourced for testing (BASH_SOURCE guard),
# the top-level block is skipped — tests set globals manually.

# Resolve workspace/repo from git remote (or env override).
# Precedence:
#   1. $BB_BASH_REMOTE → use that remote's URL
#   2. 'origin' if its URL matches bitbucket.org
#   3. First remote whose URL matches bitbucket.org
#   4. $BB_BASH_WORKSPACE + $BB_BASH_REPO env vars
#   5. Error with help
resolve_workspace_repo() {
    local url remote
    if [[ -n "${BB_BASH_REMOTE:-}" ]]; then
        url=$(git remote get-url -- "$BB_BASH_REMOTE" 2>/dev/null) \
            || die "BB_BASH_REMOTE='$BB_BASH_REMOTE' is not a known git remote in this directory"
    else
        url=$(git remote get-url origin 2>/dev/null || true)
        if ! [[ "$url" =~ (^|@|/)bitbucket\.org[:/] ]]; then
            url=""
            for remote in $(git remote 2>/dev/null); do
                local candidate
                candidate=$(git remote get-url -- "$remote" 2>/dev/null || true)
                if [[ "$candidate" =~ (^|@|/)bitbucket\.org[:/] ]]; then
                    url="$candidate"
                    break
                fi
            done
        fi
    fi

    if [[ -n "$url" ]]; then
        # Normalize: strip trailing slash, then .git, then trailing slash again
        local stripped="${url%/}"
        stripped="${stripped%.git}"
        stripped="${stripped%/}"
        # Drop everything up to and including bitbucket.org[:/]
        stripped="${stripped#*bitbucket.org[:/]}"
        WORKSPACE="${stripped%%/*}"
        local rest="${stripped#*/}"
        REPO="${rest%%/*}"  # drop any trailing path segments

        # Validate against Bitbucket slug grammar
        if ! [[ "$WORKSPACE" =~ ^[a-zA-Z0-9][a-zA-Z0-9_.-]{0,99}$ ]]; then
            die "Invalid workspace slug parsed from remote URL: '$WORKSPACE' (URL: $url)"
        fi
        if ! [[ "$REPO" =~ ^[a-zA-Z0-9][a-zA-Z0-9_.-]{0,99}$ ]]; then
            die "Invalid repo slug parsed from remote URL: '$REPO' (URL: $url)"
        fi
    else
        WORKSPACE="${BB_BASH_WORKSPACE:-}"
        REPO="${BB_BASH_REPO:-}"
        if [[ -z "$WORKSPACE" || -z "$REPO" ]]; then
            die "Cannot resolve Bitbucket workspace/repo.
Tried in order:
  1. \$BB_BASH_REMOTE env var
  2. 'origin' remote (must point to bitbucket.org)
  3. Any remote pointing to bitbucket.org
  4. \$BB_BASH_WORKSPACE and \$BB_BASH_REPO env vars

Set env vars or run from a directory inside a bitbucket.org repo."
        fi
    fi
}

# --- Helpers ---
die() { echo "Error: $*" >&2; exit 1; }

# resolve_script_dir: print the directory containing the *real* bbb script,
# resolving any chain of symlinks portably (no `readlink -f` / `realpath` —
# macOS bash 3.2 only has BSD readlink). Used at startup to anchor .env
# discovery to the real script location, not the directory of the symlink it
# was invoked through. Defined here in Helpers (not inside the BASH_SOURCE
# guard) so tests can source bbb and exercise this function directly
# without firing main().
#
# Bails via `die` on cycle (40-hop cap) or broken-symlink (resolved target's
# parent directory doesn't exist). Uses logical `pwd`, not `pwd -P`, so
# symlinks in the parent directory chain are preserved — only the script
# file's own symlink hops are resolved.
resolve_script_dir() {
    # `${1-default}` (no colon) substitutes only when $1 is UNSET; an explicit
    # empty string ("") falls through to the guard below so caller bugs like
    # `resolve_script_dir "$(cmd_that_returned_empty)"` fail loudly.
    local target=${1-${BASH_SOURCE[0]}}
    [[ -n "$target" ]] || die "resolve_script_dir: empty target"
    local link hops=0
    while [[ -L "$target" ]]; do
        hops=$((hops + 1))
        if [ "$hops" -gt 40 ]; then
            die "too many symlink hops resolving $target (cycle?)"
        fi
        link=$(readlink -- "$target")
        case "$link" in
            /*) target="$link" ;;
            *)  target="$(dirname -- "$target")/$link" ;;
        esac
    done
    local dir
    dir=$(dirname -- "$target")
    [[ -d "$dir" ]] || die "cannot resolve bbb source: $target (broken symlink?)"
    cd -- "$dir" && pwd
}

require_args() {
    local need="$1" have="$2" msg="$3"
    [[ "$have" -ge "$need" ]] || die "$msg"
}

# require_numeric <field-name> <value>
# Validates that a CLI-supplied identifier (PR id, comment id) is a
# non-negative integer before it gets interpolated into a URL path.
# Not a security boundary (the user authenticates as themselves), but
# prevents path-traversal-like surprises and gives clear error messages.
require_numeric() {
    local name="$1" val="$2"
    [[ "$val" =~ ^[0-9]+$ ]] || die "$name must be numeric, got: $val"
}

# api_get [--soft] <endpoint>
# Default: dies on HTTP >=400.
# --soft: prints body to stdout, returns 1 on HTTP >=400.
api_get() {
    local soft=0
    if [[ "${1:-}" == "--soft" ]]; then
        soft=1
        shift
    fi
    local endpoint="$1"
    local url="${BASE_URL}${endpoint}"
    local response http_code body
    response=$(curl -s -L -w "\n%{http_code}" -u "${AUTH}" "$url")
    http_code=$(echo "$response" | tail -n1)
    body=$(echo "$response" | sed '$d')
    if [[ "$http_code" -ge 400 ]]; then
        if [[ $soft -eq 1 ]]; then
            echo "$body"
            return 1
        fi
        local msg
        msg=$(echo "$body" | jq -r '.error.message // .error // empty' 2>/dev/null || echo "$body")
        die "API error (HTTP $http_code): ${msg:-$body}"
    fi
    echo "$body"
}

# api_post [--soft] <endpoint> <data>
# Default: dies on HTTP >=400.
# --soft: prints body to stdout, returns 1 on HTTP >=400.
# Use --soft for batch commands so one failure doesn't abort the loop.
# Use --soft for optional endpoints (e.g. pipelines) that may 403 on token scope.
api_post() {
    local soft=0
    if [[ "${1:-}" == "--soft" ]]; then
        soft=1
        shift
    fi
    local endpoint="$1"
    local data="$2"
    local url="${BASE_URL}${endpoint}"
    local response http_code body
    response=$(curl -s -w "\n%{http_code}" -u "${AUTH}" \
        -X POST \
        -H "Content-Type: application/json" \
        -d "$data" \
        "$url")
    http_code=$(echo "$response" | tail -n1)
    body=$(echo "$response" | sed '$d')
    if [[ "$http_code" -ge 400 ]]; then
        if [[ $soft -eq 1 ]]; then
            echo "$body"
            return 1
        fi
        local msg
        msg=$(echo "$body" | jq -r '.error.message // .error // empty' 2>/dev/null || echo "$body")
        die "API error (HTTP $http_code): ${msg:-$body}"
    fi
    echo "$body"
}

api_put() {
    local endpoint="$1"
    local data="$2"
    local url="${BASE_URL}${endpoint}"
    local response http_code body
    response=$(curl -s -w "\n%{http_code}" -u "${AUTH}" \
        -X PUT \
        -H "Content-Type: application/json" \
        -d "$data" \
        "$url")
    http_code=$(echo "$response" | tail -n1)
    body=$(echo "$response" | sed '$d')
    if [[ "$http_code" -ge 400 ]]; then
        local msg
        msg=$(echo "$body" | jq -r '.error.message // .error // empty' 2>/dev/null || echo "$body")
        die "API error (HTTP $http_code): ${msg:-$body}"
    fi
    echo "$body"
}

api_delete() {
    local endpoint="$1"
    local url="${BASE_URL}${endpoint}"
    curl -s -o /dev/null -w "%{http_code}" -u "${AUTH}" \
        -X DELETE \
        "$url"
}

# batch_action <label> <endpoint-template> <jq-success-msg> "$@"
# Loop over 1+ PR IDs, call api_post --soft on each, print per-PR result.
# Sleep 0.3s (or $BB_BASH_BATCH_DELAY) between calls when total > 1.
#
# Arguments:
#   $1 = label              human verb past tense (e.g. "approved by", "declined")
#   $2 = endpoint-template  with literal {id} placeholder (e.g. "/pullrequests/{id}/approve")
#   $3 = jq-success-msg     jq expression applied to response body for success suffix
#   $@ = PR IDs
batch_action() {
    local label="$1" endpoint_tmpl="$2" jq_msg="$3"
    shift 3
    local id resp total=$# i=0
    for id in "$@"; do
        require_numeric "PR id" "$id"
        i=$((i + 1))
        local endpoint="${endpoint_tmpl//\{id\}/$id}"
        if resp=$(api_post --soft "$endpoint" "{}"); then
            local msg
            # Coerce null/empty to "ok" inside jq so we never print "(null)".
            msg=$(echo "$resp" | jq -r "($jq_msg) // \"ok\" | tostring" 2>/dev/null || echo "ok")
            [[ -z "$msg" || "$msg" == "null" ]] && msg="ok"
            printf 'PR #%-5s %s (%s)\n' "$id" "$label" "$msg"
        else
            local err
            err=$(echo "$resp" | jq -r '.error.message // .error // "unknown error"' 2>/dev/null \
                || echo "unparseable response")
            printf 'PR #%-5s error: %s\n' "$id" "$err"
        fi
        if [[ $total -gt 1 && $i -lt $total ]]; then
            sleep "${BB_BASH_BATCH_DELAY:-0.3}"
        fi
    done
}

# _install_agent_fetch <src-rel-path> <dest-abs-or-rel-path>
# Download docs/<src> from the bbb repo (ref from BB_BASH_REF, default main)
# and write to <dest>. Honors $INSTALL_AGENT_DRY_RUN and $INSTALL_AGENT_FORCE
# (set by cmd_install_agent before calling).
_install_agent_fetch() {
    local src="$1" dest="$2"
    local ref="${BB_BASH_REF:-main}"
    local url="https://raw.githubusercontent.com/restarter/bb-bash/${ref}/docs/${src}"

    if [[ "${INSTALL_AGENT_DRY_RUN:-false}" == "true" ]]; then
        echo "  [dry-run] fetch: $url"
        echo "  [dry-run]    to: $dest"
        return 0
    fi

    if [[ -e "$dest" && "${INSTALL_AGENT_FORCE:-false}" != "true" ]]; then
        echo "  skip: $dest (exists; use --force to overwrite)"
        return 0
    fi

    mkdir -p -- "$(dirname -- "$dest")"
    if ! curl --proto '=https' --tlsv1.2 -fsSL --max-redirs 5 "$url" -o "$dest"; then
        die "failed to fetch $url"
    fi
    echo "  installed: $dest"
}

# _install_agent_md_section <dest-file>
# Append the bbb agent snippet to <dest-file> (CLAUDE.md or AGENTS.md).
# Modes:
#   - dest missing       -> create with snippet
#   - dest has marker    -> skip (use --force to re-append)
#   - dest exists no mkr -> append with '---' separator
_install_agent_md_section() {
    local dest="$1"
    local ref="${BB_BASH_REF:-main}"
    local url="https://raw.githubusercontent.com/restarter/bb-bash/${ref}/docs/bb-bash-agent-snippet.md"
    local marker='## Bitbucket via bb-bash'

    if [[ "${INSTALL_AGENT_DRY_RUN:-false}" == "true" ]]; then
        echo "  [dry-run] fetch: $url"
        if [[ -f "$dest" ]] && grep -qF "$marker" "$dest"; then
            echo "  [dry-run]   skip: $dest already contains bbb section"
        elif [[ -f "$dest" ]]; then
            echo "  [dry-run] append to: $dest"
        else
            echo "  [dry-run]   create: $dest"
        fi
        return 0
    fi

    if [[ -f "$dest" ]] && grep -qF "$marker" "$dest" && [[ "${INSTALL_AGENT_FORCE:-false}" != "true" ]]; then
        echo "  skip: $dest already has bbb section (use --force to re-append)"
        return 0
    fi

    local tmp
    tmp=$(mktemp)
    if ! curl --proto '=https' --tlsv1.2 -fsSL --max-redirs 5 "$url" -o "$tmp"; then
        rm -f "$tmp"
        die "failed to fetch $url"
    fi

    if [[ -f "$dest" ]]; then
        # Atomic-ish append: assemble (existing + separator + snippet) in a
        # tmp file on the same FS, then rename onto $dest. A SIGINT or
        # disk-full between the partial writes can't leave $dest with a
        # separator but no snippet — rename either fully succeeds or leaves
        # the original intact.
        local merged
        merged=$(mktemp -- "${dest}.bb-bash-XXXXXX")
        cat -- "$dest" > "$merged"
        printf '\n\n---\n\n' >> "$merged"
        cat -- "$tmp" >> "$merged"
        mv -- "$merged" "$dest"
        echo "  appended to: $dest"
    else
        cp -- "$tmp" "$dest"
        echo "  created: $dest"
    fi
    rm -f -- "$tmp"
}

# _agent_status_line <path>: print "  [present]" or "  [missing]" + path
_agent_status_line() {
    local p="$1"
    if [[ -e "$p" ]]; then
        echo "  [present] $p"
    else
        echo "  [missing] $p"
    fi
}

# _agent_status_line_marked <path> <marker>: like _agent_status_line but
# distinguishes "file exists with bbb section" from "file exists but no
# section yet". Used for CLAUDE.md / AGENTS.md which may pre-exist for
# other reasons.
_agent_status_line_marked() {
    local p="$1" marker="$2"
    if [[ -f "$p" ]]; then
        if grep -qF "$marker" "$p"; then
            echo "  [present] $p (has bbb section)"
        else
            echo "  [no-section] $p (exists, no bbb section)"
        fi
    else
        echo "  [missing] $p"
    fi
}

# --- Commands ---
# pr list [--state=open|merged|declined|superseded|all] [--author=<user>]
# Default --state=open preserves prior behavior.
# Note: --reviewer is not yet supported because Bitbucket BBQL doesn't
# allow filtering on `reviewers.username`. Tracked in bb-api-oja.
cmd_pr_list() {
    local state="OPEN" author=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --state=*)
                local raw="${1#--state=}"
                # POSIX-portable case conversion (avoid bash 4+ ${var,,}/${var^^})
                local raw_lower raw_upper
                raw_lower=$(echo "$raw" | tr '[:upper:]' '[:lower:]')
                raw_upper=$(echo "$raw" | tr '[:lower:]' '[:upper:]')
                case "$raw_lower" in
                    open|merged|declined|superseded)  state="$raw_upper" ;;
                    all)                              state="" ;;
                    *)                                die "Unknown --state value: $raw (open|merged|declined|superseded|all)" ;;
                esac
                ;;
            --author=*)
                author="${1#--author=}"
                ;;
            --reviewer=*)
                die "--reviewer filter is not yet supported (BBQL limitation). Tracked in bb-api-oja."
                ;;
            *)
                die "Unknown flag: $1"
                ;;
        esac
        shift
    done

    local query="pagelen=50"
    [[ -n "$state" ]] && query="${query}&state=${state}"

    # Build BBQL filter; join with " AND " via explicit loop (IFS join uses
    # only first character of IFS, so the IFS=' AND ' trick silently joins
    # on space).
    local filters=()
    if [[ -n "$author" ]]; then
        local quoted
        quoted=$(jq -Rrn --arg v "$author" '"author.username=" + ($v | tojson)')
        filters+=("$quoted")
    fi
    if [[ ${#filters[@]} -gt 0 ]]; then
        local q="${filters[0]}"
        local f
        for f in "${filters[@]:1}"; do
            q="${q} AND ${f}"
        done
        # Full URL-encode via jq @uri (handles &, +, #, %, ?, unicode, etc.
        # — not just space and quote as the previous two-substitution hack did)
        local q_encoded
        q_encoded=$(jq -rn --arg s "$q" '$s | @uri')
        query="${query}&q=${q_encoded}"
    fi

    api_get "/pullrequests?${query}" | jq -r '
        .values[] | "PR #\(.id) [\(.state)] \(.title)\n  Author: \(.author.display_name)\n  Branch: \(.source.branch.name) -> \(.destination.branch.name)\n"'
}

cmd_pr_create() {
    local target="$1"
    local title="$2"
    shift 2
    local description="${*:-}"

    [[ -n "$target" ]] || die "Target branch is required"
    [[ -n "$title" ]] || die "Title is required"

    local source
    source=$(git -C "$(pwd)" symbolic-ref --short HEAD 2>/dev/null) \
        || die "Cannot detect current git branch (run from inside the repo)"

    if [[ "$source" == "$target" ]]; then
        die "Source and target are the same branch: $source"
    fi

    local payload
    payload=$(jq -nc \
        --arg title "$title" \
        --arg desc "$description" \
        --arg src "$source" \
        --arg dst "$target" \
        '{title: $title, description: $desc, source: {branch: {name: $src}}, destination: {branch: {name: $dst}}}')

    api_post "/pullrequests" "$payload" \
        | jq -r '"PR #\(.id) created: \(.links.html.href)"'
}

# pr update <id> [--title=...] [--description=...] [--reviewers=user1,user2]
# Reviewers list is FULL replacement (Bitbucket API has no PATCH semantics).
# Reviewers passed as Bitbucket usernames; the API has been deprecating
# username as a stable identifier — tracked in bb-api-oja for UUID migration.
cmd_pr_update() {
    require_args 1 $# "Usage: bbb pr update <id> [--title=<t>] [--description=<d>] [--reviewers=u1,u2]"
    local pr_id="$1"
    require_numeric "PR id" "$pr_id"
    shift
    local title="" desc="" reviewers=""
    local title_set=0 desc_set=0 reviewers_set=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --title=*)        title="${1#--title=}"; title_set=1 ;;
            --description=*)  desc="${1#--description=}"; desc_set=1 ;;
            --reviewers=*)    reviewers="${1#--reviewers=}"; reviewers_set=1 ;;
            *)                die "Unknown flag: $1" ;;
        esac
        shift
    done
    [[ $title_set -eq 1 || $desc_set -eq 1 || $reviewers_set -eq 1 ]] \
        || die "Nothing to update (pass --title, --description, or --reviewers)"

    # Send the field if the flag was passed, even when the value is empty
    # (clearing description, for example). Previously empty values were
    # silently dropped, producing a no-op PUT that pretended to succeed.
    local payload="{}"
    [[ $title_set -eq 1 ]]    && payload=$(echo "$payload" | jq -c --arg t "$title" '. + {title: $t}')
    [[ $desc_set -eq 1 ]]     && payload=$(echo "$payload" | jq -c --arg d "$desc" '. + {description: $d}')
    if [[ $reviewers_set -eq 1 ]]; then
        local arr
        arr=$(echo "$reviewers" | jq -Rc 'split(",") | map(select(length > 0)) | map({username: .})')
        payload=$(echo "$payload" | jq -c --argjson r "$arr" '. + {reviewers: $r}')
    fi

    api_put "/pullrequests/${pr_id}" "$payload" \
        | jq -r '"PR #\(.id) updated: \(.links.html.href // "ok")"'
}

cmd_pr_show() {
    local pr_id="$1"
    require_numeric "PR id" "$pr_id"
    local pr
    pr=$(api_get "/pullrequests/${pr_id}")

    echo "$pr" | jq -r '"PR #\(.id): \(.title)
State:       \(.state)
Author:      \(.author.display_name)
Branch:      \(.source.branch.name) -> \(.destination.branch.name)
Created:     \(.created_on // "n/a")
Updated:     \(.updated_on // "n/a")
Description: \(.description // "(none)")
Link:        \(.links.html.href // "n/a")"'

    echo ""
    echo "--- Changed files ---"
    api_get "/pullrequests/${pr_id}/diffstat" | jq -r '
        .values[] | "\(.status | if . == "added" then "+" elif . == "removed" then "-" else "M" end) \(.new.path // .old.path)  (+\(.lines_added) -\(.lines_removed))"'
}

# pr open <id> — open PR in default browser (macOS 'open', Linux 'xdg-open')
cmd_pr_open() {
    require_args 1 $# "Usage: bbb pr open <id>"
    local pr_id="$1"
    require_numeric "PR id" "$pr_id"
    local url
    url=$(api_get "/pullrequests/${pr_id}" | jq -r '.links.html.href // empty')
    [[ -n "$url" ]] || die "Could not resolve PR #${pr_id} URL"

    local opener=""
    case "$(uname -s)" in
        Darwin)  opener="open" ;;
        Linux)   opener="xdg-open" ;;
        *)       echo "$url"; return 0 ;;
    esac

    if command -v "$opener" >/dev/null 2>&1; then
        "$opener" "$url"
    else
        echo "$url"
    fi
}

cmd_pr_diff() {
    local pr_id="$1"
    require_numeric "PR id" "$pr_id"
    curl -s -L -u "${AUTH}" \
        -H "Accept: text/plain" \
        "${BASE_URL}/pullrequests/${pr_id}/diff"
}

# pr checks <id> — show PR statuses + Bitbucket Pipelines for source branch
cmd_pr_checks() {
    require_args 1 $# "Usage: bbb pr checks <id>"
    local pr_id="$1"
    require_numeric "PR id" "$pr_id"

    # Fetch PR to get source branch name
    local pr branch
    pr=$(api_get "/pullrequests/${pr_id}")
    branch=$(echo "$pr" | jq -r '.source.branch.name')

    # 1) PR-level statuses (external CI: GH Actions, Jenkins, etc.)
    echo "--- PR statuses ---"
    local statuses
    statuses=$(api_get "/pullrequests/${pr_id}/statuses?pagelen=50")
    local status_count
    status_count=$(echo "$statuses" | jq -r '.values | length')
    if [[ "$status_count" -eq 0 ]]; then
        echo "  (no external statuses)"
    else
        echo "$statuses" | jq -r '
            def norm(s):
              {SUCCESSFUL: "pass", SUCCESS: "pass", PASSED: "pass",
               INPROGRESS: "running", IN_PROGRESS: "running", PENDING: "running", RUNNING: "running",
               FAILED: "fail", FAILURE: "fail", ERROR: "fail",
               STOPPED: "stopped", HALTED: "stopped", CANCELLED: "stopped"}
              [s | ascii_upcase] // (s | ascii_downcase);
            .values[] | "  [\(norm(.state))] \(.name // .key) — \(.url // "no url")"'
    fi

    # 2) Bitbucket Pipelines for the source branch
    # Use api_get --soft so missing read:pipeline scope degrades gracefully.
    # URL-encode branch name (may contain slashes, e.g. feature/foo)
    echo ""
    echo "--- Bitbucket Pipelines (branch: $branch) ---"
    local branch_encoded
    branch_encoded=$(jq -rn --arg b "$branch" '$b | @uri')
    local pipes
    if pipes=$(api_get --soft "/pipelines/?target.ref_name=${branch_encoded}&sort=-created_on&pagelen=10"); then
        local pipe_count
        pipe_count=$(echo "$pipes" | jq -r '.values | length')
        if [[ "$pipe_count" -eq 0 ]]; then
            echo "  (no pipelines for this branch)"
        else
            echo "$pipes" | jq -r '
                def norm(s):
                  {SUCCESSFUL: "pass", SUCCESS: "pass", PASSED: "pass",
                   INPROGRESS: "running", IN_PROGRESS: "running", PENDING: "running", RUNNING: "running",
                   FAILED: "fail", FAILURE: "fail", ERROR: "fail",
                   STOPPED: "stopped", HALTED: "stopped", CANCELLED: "stopped",
                   PAUSED: "stopped"}
                  [s | ascii_upcase] // (s | ascii_downcase);
                .values[]
                | "  #\(.build_number) [\(norm(.state.result.name // .state.name))] \(.created_on[:16]) — \(.target.commit.hash[:7]) by \(.creator.display_name // "?")"'
        fi
    else
        echo "  (pipelines unavailable — token may lack read:pipeline scope)"
    fi
}

cmd_pr_comments() {
    local pr_id="$1"
    require_numeric "PR id" "$pr_id"
    api_get "/pullrequests/${pr_id}/comments?pagelen=100" | jq -r '
        .values[]
        | select(.deleted != true)
        | "[#\(.id)] [\(.created_on[:16])] \(.user.display_name)" +
          (if .inline then " @ \(.inline.path):\(.inline.to // .inline.from)" else "" end) +
          (if .parent then " (reply to #\(.parent.id))" else "" end) +
          ":\n\(.content.raw)\n---"'
}

cmd_pr_comment() {
    local pr_id="$1"
    require_numeric "PR id" "$pr_id"
    shift
    local text="$*"
    [[ -n "$text" ]] || die "Comment text is required"
    local payload
    payload=$(jq -nc --arg text "$text" '{content: {raw: $text}}')
    api_post "/pullrequests/${pr_id}/comments" "$payload" \
        | jq -r '"Comment posted: \(.links.html.href // "ok")"'
}

cmd_pr_inline() {
    local side="to"  # default: comment on new code
    if [[ "${1:-}" == "--old" ]]; then
        side="from"
        shift
    fi
    require_args 4 $# "Usage: bbb pr inline [--old] <id> <path> <line> <text>"
    local pr_id="$1"
    require_numeric "PR id" "$pr_id"
    local path="$2"
    local line="$3"
    [[ "$line" =~ ^[0-9]+$ ]] || die "Line must be a number, got: $line"
    shift 3
    local text="$*"
    [[ -n "$text" ]] || die "Comment text is required"
    # $side is "to" or "from" — set internally above, never user input.
    # Interpolated into the jq filter literal because jq has no clean dynamic-key form.
    local payload
    payload=$(jq -nc --arg text "$text" --arg path "$path" --argjson line "$line" \
        "{content: {raw: \$text}, inline: {path: \$path, ${side}: \$line}}")
    api_post "/pullrequests/${pr_id}/comments" "$payload" \
        | jq -r '"Inline comment posted: \(.inline.path):\(.inline.to // .inline.from) - \(.links.html.href // "ok")"'
}

cmd_pr_approve() {
    require_args 1 $# "Usage: bbb pr approve <id> [id ...]"
    batch_action "approved by" "/pullrequests/{id}/approve" '.user.display_name // "ok"' "$@"
}

cmd_pr_decline() {
    require_args 1 $# "Usage: bbb pr decline <id> [id ...]"
    batch_action "declined" "/pullrequests/{id}/decline" '.state // "DECLINED"' "$@"
}

# pr merge <id> [--squash|--commit|--ff] [--delete-branch] [--message=<text>]
# Default strategy: merge_commit (Bitbucket's most common UI default).
# Explicit override via flags. No repo-default fetch (the API field
# `.mainbranch.merge_commit_default` does not exist).
cmd_pr_merge() {
    require_args 1 $# "Usage: bbb pr merge <id> [--squash|--commit|--ff] [--delete-branch] [--message=<text>]"
    local pr_id="$1"
    require_numeric "PR id" "$pr_id"
    shift
    local strategy="merge_commit" close_source="false" message=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --squash)         strategy="squash" ;;
            --commit)         strategy="merge_commit" ;;
            --ff)             strategy="fast_forward" ;;
            --delete-branch)  close_source="true" ;;
            --message=*)      message="${1#--message=}" ;;
            *)                die "Unknown flag: $1" ;;
        esac
        shift
    done

    # Bitbucket Cloud uses field name `type` (not `merge_strategy`) for the
    # merge endpoint payload.
    local payload
    payload=$(jq -nc \
        --arg type "$strategy" \
        --argjson close "$close_source" \
        --arg msg "$message" \
        '{type: $type, close_source_branch: $close} + (if $msg == "" then {} else {message: $msg} end)')

    local result hash
    result=$(api_post "/pullrequests/${pr_id}/merge" "$payload")
    hash=$(echo "$result" | jq -r '.merge_commit.hash // ""' | cut -c1-7)
    echo "PR #${pr_id} merged${hash:+ ($hash)} — strategy: $strategy"
}

cmd_pr_reply() {
    local pr_id="$1"
    local comment_id="$2"
    require_numeric "PR id" "$pr_id"
    require_numeric "Comment id" "$comment_id"
    shift 2
    local text="$*"
    [[ -n "$text" ]] || die "Reply text is required"
    local payload
    payload=$(jq -nc --arg text "$text" --argjson cid "$comment_id" \
        '{content: {raw: $text}, parent: {id: $cid}}')
    api_post "/pullrequests/${pr_id}/comments" "$payload" \
        | jq -r '"Reply posted to #\(.parent.id): \(.links.html.href // "ok")"'
}

cmd_pr_edit_comment() {
    local pr_id="$1"
    local comment_id="$2"
    require_numeric "PR id" "$pr_id"
    require_numeric "Comment id" "$comment_id"
    shift 2
    local text="$*"
    [[ -n "$text" ]] || die "Comment text is required"
    local payload
    payload=$(jq -nc --arg text "$text" '{content: {raw: $text}}')
    api_put "/pullrequests/${pr_id}/comments/${comment_id}" "$payload" \
        | jq -r '"Comment #\(.id) updated: \(.links.html.href // "ok")"'
}

cmd_pr_delete_comment() {
    local pr_id="$1"
    local comment_id="$2"
    require_numeric "PR id" "$pr_id"
    require_numeric "Comment id" "$comment_id"
    local status
    status=$(api_delete "/pullrequests/${pr_id}/comments/${comment_id}")
    if [[ "$status" == "204" ]]; then
        echo "Comment ${comment_id} deleted"
    else
        echo "Failed to delete comment ${comment_id} (HTTP ${status})"
    fi
}

cmd_raw() {
    local endpoint="$1"
    api_get "$endpoint" | jq '.'
}

cmd_raw_post() {
    local endpoint="$1"
    local data="$2"
    api_post "$endpoint" "$data" | jq '.'
}

# install-agent: drop AI-agent integration artifacts into $PWD.
# Flags combine; no flag = interactive prompt (letter codes).
# Unlike pr/raw commands this one doesn't hit Bitbucket and is allowed to
# run without auth or a Bitbucket-repo CWD — the top-level guard at the
# bottom of this file short-circuits credential resolution for it.
cmd_install_agent() {
    local want_rule=false want_skill=false want_claudemd=false want_agents=false
    local has_flag=false
    INSTALL_AGENT_DRY_RUN=false
    INSTALL_AGENT_FORCE=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --rule)     want_rule=true; has_flag=true ;;
            --skill)    want_skill=true; has_flag=true ;;
            --claudemd) want_claudemd=true; has_flag=true ;;
            --agents)   want_agents=true; has_flag=true ;;
            --dry-run)  INSTALL_AGENT_DRY_RUN=true ;;
            --force)    INSTALL_AGENT_FORCE=true ;;
            -h|--help)
                cat <<'EOF'
Usage: bbb install-agent [--rule] [--skill] [--claudemd] [--agents] [--dry-run] [--force]

Drop AI-agent integration artifacts into the current directory.

Artifacts (combine any subset):
  --rule       .claude/rules/bb-bash-rule.md       (Claude Code, auto-load)
  --skill      .claude/skills/bb-bash/SKILL.md     (Claude Code, lazy-load)
  --claudemd   ./CLAUDE.md                         (append "## Bitbucket via bb-bash" section)
  --agents     ./AGENTS.md                         (append "## Bitbucket via bb-bash" section)

Modifiers:
  --dry-run    Print actions, do not write to disk
  --force      Overwrite existing files / re-append to CLAUDE.md/AGENTS.md

Without flags: interactive prompt (enter letter codes like 'rsca').

Env:
  BB_BASH_REF   Git ref to fetch artifacts from (default: main).
               Pin to a release tag for reproducibility, e.g. BB_BASH_REF=v0.1.2.

Examples:
  bbb install-agent --rule --skill
  bbb install-agent --claudemd --dry-run
  BB_BASH_REF=v0.1.2 bbb install-agent --rule --skill --agents
EOF
                return 0
                ;;
            *) die "Unknown flag: $1 (run 'bbb install-agent --help')" ;;
        esac
        shift
    done

    if [[ "$has_flag" != "true" ]]; then
        # Under set -e, read -r -p crashes with no message on EOF/closed-stdin
        # (CI, `bbb install-agent < /dev/null`, piped non-tty contexts).
        # Short-circuit with a clear instruction instead.
        [[ -t 0 ]] || die "no flags provided and stdin is not a tty; specify --rule/--skill/--claudemd/--agents"
        echo "Project: $PWD"
        echo "Status:"
        _agent_status_line ".claude/rules/bb-bash-rule.md"
        _agent_status_line ".claude/skills/bb-bash/SKILL.md"
        _agent_status_line_marked "CLAUDE.md" '## Bitbucket via bb-bash'
        _agent_status_line_marked "AGENTS.md" '## Bitbucket via bb-bash'
        echo ""
        echo "Install: [r=rule, s=skill, c=CLAUDE.md, a=AGENTS.md, q=quit]"
        local choice
        read -r -p "Combine letters (e.g. 'rs', 'ca', 'rsca') or q to quit: " choice
        if [[ "$choice" == "q" || -z "$choice" ]]; then
            echo "cancelled"
            return 0
        fi
        # Whitelist-validate before per-letter matching. Without this, any string
        # containing 'r' (e.g. "hello world") would silently turn on want_rule.
        [[ "$choice" =~ ^[rsca]+$ ]] || die "invalid letters in '$choice' (allowed: r/s/c/a, or q to quit)"
        [[ "$choice" == *r* ]] && want_rule=true
        [[ "$choice" == *s* ]] && want_skill=true
        [[ "$choice" == *c* ]] && want_claudemd=true
        [[ "$choice" == *a* ]] && want_agents=true
    fi

    local mode_label
    if [[ "$INSTALL_AGENT_DRY_RUN" == "true" ]]; then
        mode_label="dry-run"
    else
        mode_label="live"
    fi
    echo "Installing into $PWD ($mode_label, ref=${BB_BASH_REF:-main})"

    $want_rule     && _install_agent_fetch "bb-bash-rule.md"        ".claude/rules/bb-bash-rule.md"
    $want_skill    && _install_agent_fetch "bb-bash-skill/SKILL.md" ".claude/skills/bb-bash/SKILL.md"
    $want_claudemd && _install_agent_md_section "CLAUDE.md"
    $want_agents   && _install_agent_md_section "AGENTS.md"

    echo "Done."
}

# --- Help ---
usage() {
    # WORKSPACE/REPO may be unset when usage() runs through the short-circuit
    # path (help / install-agent / -h / --help), which skips resolve_workspace_repo.
    # Use safe defaults so `bbb help` works outside a bitbucket.org repo.
    echo "bb-bash - Bitbucket API wrapper for ${WORKSPACE:-<workspace>}/${REPO:-<repo>}"
    echo ""
    echo "Usage:"
    echo "  bbb pr list [--state=open|merged|declined|superseded|all] [--author=<user>]   List PRs"
    echo "  bbb pr create <target> <title> [desc]        Create PR from current branch"
    echo "  bbb pr update <id> [--title=<t>] [--description=<d>] [--reviewers=u1,u2]  Update PR metadata"
    echo "  bbb pr show <id>                             PR details + changed files"
    echo "  bbb pr open <id>                             Open PR in default browser"
    echo "  bbb pr diff <id>                             Full diff"
    echo "  bbb pr checks <id>                           Show CI statuses + Bitbucket Pipelines"
    echo "  bbb pr comments <id>                         List comments"
    echo "  bbb pr comment <id> <text>                   Add general comment"
    echo "  bbb pr inline [--old] <id> <path> <line> <text>  Inline comment (default new code, --old for deleted)"
    echo "  bbb pr approve <id> [id ...]                 Approve PR, batch-capable"
    echo "  bbb pr decline <id> [id ...]                 Decline (close without merge), batch-capable"
    echo "  bbb pr merge <id> [--squash|--commit|--ff] [--delete-branch]  Merge PR (default: merge_commit)"
    echo "  bbb pr reply <pr_id> <comment_id> <text>   Reply to a comment"
    echo "  bbb pr edit-comment <pr_id> <comment_id> <text>  Edit a comment"
    echo "  bbb pr delete-comment <pr_id> <comment_id>   Delete a comment"
    echo "  bbb raw <endpoint>                           Raw GET  (e.g. /pullrequests)"
    echo "  bbb raw-post <endpoint> <json>               Raw POST"
    echo "  bbb install-agent [--rule] [--skill] [--claudemd] [--agents] [--dry-run] [--force]"
    echo "                                                  Drop AI-agent integration artifacts into \$PWD"
    echo ""
    echo "Inline comments: omit --old for new/added lines, include --old for deleted lines."
    echo ""
    echo "Configuration (via .env file or environment variables):"
    echo "  BB_BASH_EMAIL      Bitbucket account email   (required)"
    echo "  BB_BASH_TOKEN      Bitbucket API token       (required)"
    echo "  BB_BASH_WORKSPACE  Bitbucket workspace       (optional, auto-detected from git remote)"
    echo "  BB_BASH_REPO       Repository slug           (optional, auto-detected from git remote)"
    echo "  BB_BASH_REMOTE     Git remote name override  (optional, default: scan for bitbucket.org)"
    echo "  BB_BASH_REF        Git ref for install-agent (optional, default: main)"
    echo ""
    echo "Copy .env.example to .env and fill in your values."
}

# --- Router ---
main() {
    if [[ $# -lt 1 ]]; then
        usage
        exit 0
    fi

    local cmd="$1"
    shift

    case "$cmd" in
        pr)
            if [[ $# -lt 1 ]]; then
                usage
                exit 1
            fi
            local subcmd="$1"
            shift
            case "$subcmd" in
                list)           cmd_pr_list "$@" ;;
                create)         require_args 2 $# "Usage: bbb pr create <target> <title> [description]"; cmd_pr_create "$@" ;;
                update)         cmd_pr_update "$@" ;;
                show)           require_args 1 $# "Usage: bbb pr show <id>"; cmd_pr_show "$1" ;;
                open)           cmd_pr_open "$@" ;;
                diff)           require_args 1 $# "Usage: bbb pr diff <id>"; cmd_pr_diff "$1" ;;
                checks)         cmd_pr_checks "$@" ;;
                comments)       require_args 1 $# "Usage: bbb pr comments <id>"; cmd_pr_comments "$1" ;;
                comment)        require_args 2 $# "Usage: bbb pr comment <id> <text>"; cmd_pr_comment "$@" ;;
                inline)         cmd_pr_inline "$@" ;;
                approve)        cmd_pr_approve "$@" ;;
                decline)        cmd_pr_decline "$@" ;;
                merge)          cmd_pr_merge "$@" ;;
                reply)          require_args 3 $# "Usage: bbb pr reply <pr_id> <comment_id> <text>"; cmd_pr_reply "$@" ;;
                edit-comment)   require_args 3 $# "Usage: bbb pr edit-comment <pr_id> <comment_id> <text>"; cmd_pr_edit_comment "$@" ;;
                delete-comment) require_args 2 $# "Usage: bbb pr delete-comment <pr_id> <comment_id>"; cmd_pr_delete_comment "$1" "$2" ;;
                *)              usage; exit 1 ;;
            esac
            ;;
        raw)           require_args 1 $# "Usage: bbb raw <endpoint>"; cmd_raw "$1" ;;
        raw-post)      require_args 2 $# "Usage: bbb raw-post <endpoint> <json>"; cmd_raw_post "$1" "$2" ;;
        install-agent) cmd_install_agent "$@" ;;
        help)          usage ;;
        *)             usage; exit 1 ;;
    esac
}

# --- Top-level execution ---
# Run only when executed directly (not when sourced for testing).
# Test harnesses source bbb to access function definitions, then set
# WORKSPACE/REPO/BASE_URL/AUTH manually — see test/test_helper.bash.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    # Load .env from the script's REAL directory (resolved through any number
    # of symlink hops by resolve_script_dir in Helpers). Kept inside the guard
    # so test harnesses that source bbb don't inherit developer credentials.
    SCRIPT_DIR=$(resolve_script_dir)
    # shellcheck source=/dev/null
    [[ -f "${SCRIPT_DIR}/.env" ]] && source "${SCRIPT_DIR}/.env"

    # install-agent + help don't hit Bitbucket — skip auth/repo resolution
    # so users can run them without .env configured or outside a git repo.
    case "${1:-}" in
        install-agent|help|-h|--help|"")
            main "$@"
            ;;
        *)
            BB_BASH_EMAIL="${BB_BASH_EMAIL:?BB_BASH_EMAIL is required (set in .env or environment)}"
            BB_BASH_TOKEN="${BB_BASH_TOKEN:?BB_BASH_TOKEN is required (set in .env or environment)}"
            resolve_workspace_repo
            BASE_URL="https://api.bitbucket.org/2.0/repositories/${WORKSPACE}/${REPO}"
            AUTH="${BB_BASH_EMAIL}:${BB_BASH_TOKEN}"
            main "$@"
            ;;
    esac
fi
