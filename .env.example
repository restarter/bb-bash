# Bitbucket API credentials
# Copy this file to .env, fill in your values, and chmod 600.
#
# Create an API token: https://bitbucket.org/account/settings/api-tokens/
# Required scopes:
#   - read:repository:bitbucket
#   - read:pullrequest:bitbucket
#   - write:pullrequest:bitbucket
#   - read:pipeline:bitbucket    (optional; only for 'pr checks' to show Bitbucket Pipelines)

BB_API_EMAIL="your-email@example.com"
BB_API_TOKEN="your-api-token-here"

# Optional overrides:
# Workspace/repo are auto-detected from the current directory's git remote
# (see docs/design.md). Uncomment to force a specific value when running
# outside a git repo:
# BB_API_WORKSPACE="your-workspace"
# BB_API_REPO="your-repo"
#
# Override which git remote to use for auto-detect (default: scan for any
# remote pointing to bitbucket.org):
# BB_API_REMOTE="bb"
