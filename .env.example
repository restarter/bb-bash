# Bitbucket API credentials
# Copy this file to .env and fill in your values
#
# Create app password: Bitbucket > Settings > App passwords
# Required scopes: read:repository, read:pullrequest, write:pullrequest

BB_API_EMAIL="your-email@example.com"
BB_API_TOKEN="your-app-password-here"
BB_API_WORKSPACE="your-workspace"
BB_API_REPO="your-repo"
